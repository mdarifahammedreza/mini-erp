# Application Configs
NODE_ENV=development
PORT=5000
API_PREFIX=api/v1

# MongoDB Configs
MONGO_URI=mongodb://localhost:27018/mini-erp
MONGODB_URI=mongodb://localhost:27018/mini-erp
MONGO_USER=root
MONGO_PASSWORD=password
MONGO_DB=mini-erp

# JWT Settings
JWT_ACCESS_SECRET=super-secret-access-token-key-must-be-long-32-chars
JWT_REFRESH_SECRET=super-secret-refresh-token-key-must-be-long-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# CORS Settings
CORS_ORIGINS=http://localhost:5173

# File Upload Settings
UPLOAD_DEST=./uploads/products
UPLOAD_MAX_SIZE=5242880

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
